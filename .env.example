# === LLM Backend ===
LLM_PROVIDER=groq               # "local" (LM Studio) or "groq"
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=liquid/lfm2.5-1.2b  # model name loaded in LM Studio
GROQ_API_KEY=                   # required — get a free key at https://console.groq.com/keys
GROQ_MODEL=llama-3.3-70b-versatile

# === ChromaDB ===
CHROMA_URL=http://localhost:8000

# === Whisper ===
WHISPER_MODEL=large-v3-turbo    # tiny, base, small, medium, large-v3-turbo, large-v3

# === Menu Bar (Mac only) ===
HOTKEY=cmd+shift+m

# === Server ===
SERVER_HOST=127.0.0.1
SERVER_PORT=7860
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR
